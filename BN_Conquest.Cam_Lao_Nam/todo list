_this addEventHandler ["GetIn", {
    params ["_vehicle", "_role", "_unit", "_turret"];
    [_unit] spawn {
        private _player = _this select 0;
        while {vehicle _player != _player} do {
            if (cameraView != "INTERNAL") then {
                _player switchCamera "INTERNAL";
            };
            sleep 0.1;
        };
    };
}];



